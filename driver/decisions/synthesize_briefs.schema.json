{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Synthesize Briefs Decision",
  "description": "Orchestrator S2 decision: consume multiple audit briefs (from independent lenses: security, correctness, UX, ideation, etc.) and produce a consolidated context pack: unified findings list, intra-lens relationships, priority ordering for the PM/orchestrator, and next-steps clarifications.",
  "type": "object",
  "required": ["verdict", "evidence"],
  "properties": {
    "decision_type": {
      "type": "string",
      "const": "synthesize_briefs"
    },
    "input": {
      "type": "object",
      "description": "Multiple audit briefs to synthesize",
      "required": ["briefs"],
      "properties": {
        "briefs": {
          "type": "array",
          "description": "Audit briefs from different lenses",
          "items": {
            "type": "object",
            "required": ["lens", "findings"],
            "properties": {
              "lens": {
                "type": "string",
                "description": "Name of the audit lens (e.g., 'security', 'correctness', 'ui_ux')"
              },
              "timestamp": {
                "type": "string",
                "description": "ISO8601 timestamp when brief was generated"
              },
              "findings": {
                "type": "array",
                "description": "List of findings from this lens",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "category": {
                      "type": "string"
                    },
                    "severity": {
                      "type": "string"
                    }
                  }
                }
              },
              "summary": {
                "type": "string",
                "description": "Brief summary of key themes from this lens"
              }
            }
          }
        },
        "prior_synthesis": {
          "type": "object",
          "description": "Previous synthesis if this is a re-synthesis",
          "properties": {
            "wave": {
              "type": "integer"
            },
            "consolidated_items": {
              "type": "integer",
              "description": "Number of items in prior synthesis"
            }
          }
        },
        "dedup_context": {
          "type": "object",
          "description": "Context for deduplication",
          "properties": {
            "known_duplicates": {
              "type": "array",
              "description": "Findings previously marked as duplicates",
              "items": {
                "type": "object",
                "properties": {
                  "finding_ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["synthesized", "completed", "undetermined"],
      "description": "Synthesis decision: briefs synthesized and consolidated, or incomplete?"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in this synthesis (0.0-1.0). Lower if lenses contradict each other or findings are ambiguous."
    },
    "evidence": {
      "type": "array",
      "description": "Citations to the input briefs and their findings (mandatory, >=1 item)",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "consolidated_findings": {
      "type": "array",
      "description": "Unified list of findings, deduplicated and organized by priority",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Consolidated finding ID"
          },
          "description": {
            "type": "string"
          },
          "source_lenses": {
            "type": "array",
            "description": "Which audit lenses flagged this",
            "items": {
              "type": "string"
            }
          },
          "category": {
            "type": "string",
            "enum": ["defect", "false_positive", "enhancement", "refactor", "tech_debt", "docs_drift", "other"]
          },
          "priority": {
            "type": "string",
            "enum": ["p0", "p1", "p2", "p3"]
          }
        }
      }
    }
  }
}
