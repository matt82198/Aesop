{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Synthesize Briefs Decision",
  "description": "Orchestrator S2 decision: consume multiple audit briefs (from independent lenses: security, correctness, UX, ideation, etc.) and produce a consolidated context pack: unified findings list, intra-lens relationships, priority ordering for the PM/orchestrator, and next-steps clarifications.",
  "type": "object",
  "required": ["verdict", "evidence"],
  "properties": {
    "decision_type": {
      "type": "string",
      "const": "synthesize_briefs"
    },
    "input": {
      "type": "object",
      "description": "Multiple audit briefs to synthesize",
      "required": ["briefs"],
      "properties": {
        "briefs": {
          "type": "array",
          "description": "Audit briefs from different lenses",
          "items": {
            "type": "object",
            "required": ["lens", "findings"],
            "properties": {
              "lens": {
                "type": "string",
                "description": "Name of the audit lens (e.g., 'security', 'correctness', 'ui_ux')"
              },
              "timestamp": {
                "type": "string",
                "description": "ISO8601 timestamp when brief was generated"
              },
              "findings": {
                "type": "array",
                "description": "List of findings from this lens",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "category": {
                      "type": "string"
                    },
                    "severity": {
                      "type": "string"
                    }
                  }
                }
              },
              "summary": {
                "type": "string",
                "description": "Brief summary of key themes from this lens"
              }
            }
          }
        },
        "prior_synthesis": {
          "type": "object",
          "description": "Previous synthesis if this is a re-synthesis",
          "properties": {
            "wave": {
              "type": "integer"
            },
            "consolidated_items": {
              "type": "integer",
              "description": "Number of items in prior synthesis"
            }
          }
        },
        "dedup_context": {
          "type": "object",
          "description": "Context for deduplication",
          "properties": {
            "known_duplicates": {
              "type": "array",
              "description": "Findings previously marked as duplicates",
              "items": {
                "type": "object",
                "properties": {
                  "finding_ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "description": "The synthesized brief (consolidated findings and structure)",
      "required": ["consolidated_findings"],
      "properties": {
        "consolidated_findings": {
          "type": "array",
          "description": "Unified list of findings, deduplicated and organized by priority",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Consolidated finding ID"
              },
              "description": {
                "type": "string"
              },
              "source_lenses": {
                "type": "array",
                "description": "Which audit lenses flagged this",
                "items": {
                  "type": "string"
                }
              },
              "source_finding_ids": {
                "type": "array",
                "description": "Original finding IDs that were consolidated into this one",
                "items": {
                  "type": "string"
                }
              },
              "category": {
                "type": "string",
                "enum": ["defect", "false_positive", "enhancement", "refactor", "tech_debt", "docs_drift", "other"]
              },
              "priority": {
                "type": "string",
                "enum": ["p0", "p1", "p2", "p3"]
              },
              "suggested_backlog_item": {
                "type": "boolean",
                "description": "Should this be added to the wave backlog?"
              }
            }
          }
        },
        "duplicate_map": {
          "type": "object",
          "description": "Finding IDs that were consolidated (merged into consolidated IDs)",
          "additionalProperties": {
            "type": "string",
            "description": "Maps old finding ID to consolidated finding ID"
          }
        },
        "intra_finding_relationships": {
          "type": "array",
          "description": "Dependencies and relationships between findings",
          "items": {
            "type": "object",
            "properties": {
              "finding_id": {
                "type": "string"
              },
              "related_to": {
                "type": "string"
              },
              "relationship_type": {
                "type": "string",
                "enum": ["blocks", "caused_by", "suggests", "contradicts", "related"]
              }
            }
          }
        },
        "summary_by_theme": {
          "type": "object",
          "description": "High-level themes that emerged from the briefs",
          "properties": {
            "key_themes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "theme": {
                    "type": "string"
                  },
                  "finding_count": {
                    "type": "integer"
                  },
                  "findings": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "changes_from_prior": {
          "type": "string",
          "description": "If re-synthesizing, what changed since the prior synthesis"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in this synthesis (0.0-1.0). Lower if lenses contradict each other or findings are ambiguous."
    },
    "evidence": {
      "type": "array",
      "description": "Citations to the input briefs and their findings",
      "required": true,
      "items": {
        "type": "object",
        "required": ["source_brief", "description"],
        "properties": {
          "source_brief": {
            "type": "string",
            "description": "Name of the audit lens brief"
          },
          "finding_id": {
            "type": "string",
            "description": "Finding ID from that brief"
          },
          "finding_description": {
            "type": "string",
            "description": "The finding text"
          },
          "description": {
            "type": "string",
            "description": "Why this evidence informs the synthesis"
          }
        }
      }
    }
  }
}
