{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review Diff Decision",
  "description": "Orchestrator S2 decision: given a code diff from a worker agent, determine: does it correctly implement the requested change? Are there defects, style issues, or oversights? Should it be merged or sent back for revision?",
  "type": "object",
  "required": ["verdict", "evidence"],
  "properties": {
    "decision_type": {
      "type": "string",
      "const": "review_diff"
    },
    "input": {
      "type": "object",
      "description": "The diff to review and its context",
      "required": ["diff", "original_intent"],
      "properties": {
        "diff": {
          "type": "object",
          "description": "The changeset to review",
          "required": ["branch", "files_changed"],
          "properties": {
            "branch": {
              "type": "string",
              "description": "Branch name (e.g., feat/orchestrator-decisions-catalog)"
            },
            "commit_sha": {
              "type": "string",
              "description": "Commit hash if available"
            },
            "files_changed": {
              "type": "array",
              "description": "List of files modified",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string",
                    "description": "File path (repo-relative)"
                  },
                  "status": {
                    "type": "string",
                    "enum": ["added", "modified", "deleted", "renamed"]
                  },
                  "additions": {
                    "type": "integer"
                  },
                  "deletions": {
                    "type": "integer"
                  },
                  "patch": {
                    "type": "string",
                    "description": "Unified diff for this file (truncated to 1000 chars for schema validation)"
                  }
                }
              }
            },
            "tests_passing": {
              "type": "boolean",
              "description": "Did the worker report that tests pass?"
            },
            "test_exit_code": {
              "type": "integer",
              "description": "Exit code from test run (0 = pass)"
            }
          }
        },
        "original_intent": {
          "type": "object",
          "description": "What the worker was asked to implement",
          "required": ["prompt_excerpt"],
          "properties": {
            "prompt_excerpt": {
              "type": "string",
              "description": "The relevant part of the worker dispatch prompt"
            },
            "item_slug": {
              "type": "string",
              "description": "Wave backlog item identifier"
            },
            "contract_hint": {
              "type": "string",
              "description": "Domain contract or specification the change should fulfill"
            }
          }
        },
        "worker_context": {
          "type": "object",
          "description": "Information about the agent who wrote the code",
          "properties": {
            "agent_model": {
              "type": "string",
              "description": "Model used (e.g., 'claude-haiku-4')"
            },
            "owned_files": {
              "type": "array",
              "description": "Files the agent was permitted to modify",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "description": "The code review decision",
      "required": ["approval_status"],
      "properties": {
        "approval_status": {
          "type": "string",
          "enum": ["approved", "approved_with_minor_nits", "request_changes", "undetermined"],
          "description": "Can this diff be merged?"
        },
        "implements_intent": {
          "type": "boolean",
          "description": "Does the diff correctly implement the requested change?"
        },
        "issues_found": {
          "type": "array",
          "description": "Any defects, style issues, or oversights discovered",
          "items": {
            "type": "object",
            "properties": {
              "severity": {
                "type": "string",
                "enum": ["blocker", "major", "minor", "nit"]
              },
              "file": {
                "type": "string",
                "description": "File affected"
              },
              "line": {
                "type": "integer",
                "description": "Line number (approx)"
              },
              "issue_type": {
                "type": "string",
                "enum": ["logic_defect", "style", "performance", "test_gap", "doc_drift", "ownership_violation", "security", "other"]
              },
              "description": {
                "type": "string"
              },
              "suggested_fix": {
                "type": "string"
              }
            }
          }
        },
        "out_of_scope_detected": {
          "type": "boolean",
          "description": "Did the worker modify files outside its owned set?"
        },
        "test_coverage_adequate": {
          "type": "boolean",
          "description": "Are changes backed by adequate tests?"
        },
        "requires_revision": {
          "type": "boolean",
          "description": "Should this be sent back to the worker for revision?"
        },
        "revision_notes": {
          "type": "string",
          "description": "If revision required, what should be fixed"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in this review (0.0-1.0). Lower if the intent is vague or edge cases unclear."
    },
    "evidence": {
      "type": "array",
      "description": "Citations supporting this review verdict",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["code_location", "test_failure", "contract_spec", "prior_review", "test_output"]
          },
          "file": {
            "type": "string",
            "description": "File path in the diff"
          },
          "lines": {
            "type": "string",
            "description": "Line range in the diff"
          },
          "excerpt": {
            "type": "string",
            "description": "Relevant code snippet"
          },
          "description": {
            "type": "string",
            "description": "Why this evidence matters to the review"
          },
          "link": {
            "type": "string",
            "description": "Link to spec, prior PR, or contract"
          }
        }
      }
    }
  }
}
