{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Decide Repair Decision",
  "description": "Orchestrator S2 decision: a wave item failed its test; analyze the failure and test output, then decide: is it worth a repair attempt? What strategy should the repair round use? Should we escalate or mark it for manual review instead?",
  "type": "object",
  "required": ["verdict", "evidence"],
  "properties": {
    "decision_type": {
      "type": "string",
      "const": "decide_repair"
    },
    "input": {
      "type": "object",
      "description": "The failed build and its context",
      "required": ["failed_item", "test_output"],
      "properties": {
        "failed_item": {
          "type": "object",
          "description": "The wave item that failed",
          "required": ["slug", "branch"],
          "properties": {
            "slug": {
              "type": "string",
              "description": "Item identifier (e.g., 'feat/x', 'fix/y')"
            },
            "branch": {
              "type": "string",
              "description": "Git branch name"
            },
            "model_used": {
              "type": "string",
              "description": "Model that built this item (e.g., 'claude-haiku-4')"
            },
            "owned_files": {
              "type": "array",
              "description": "Files the agent was authorized to modify",
              "items": {
                "type": "string"
              }
            },
            "prompt_excerpt": {
              "type": "string",
              "description": "The dispatch prompt (first 500 chars)"
            }
          }
        },
        "test_output": {
          "type": "object",
          "description": "Test failure details",
          "required": ["test_command", "exit_code"],
          "properties": {
            "test_command": {
              "type": "string",
              "description": "The test command that was run"
            },
            "exit_code": {
              "type": "integer",
              "description": "Exit code (non-zero indicates failure)"
            },
            "stdout": {
              "type": "string",
              "description": "Test stdout (last 1000 chars)"
            },
            "stderr": {
              "type": "string",
              "description": "Test stderr (last 1000 chars)"
            },
            "failure_pattern": {
              "type": "string",
              "description": "High-level failure category detected (e.g., 'assertion_error', 'timeout', 'import_error', 'integration_failure')"
            }
          }
        },
        "repair_context": {
          "type": "object",
          "description": "Information about prior repair attempts",
          "properties": {
            "round": {
              "type": "integer",
              "description": "Which repair round is this (1 = first attempt, 2 = retry, etc.)"
            },
            "prior_rounds": {
              "type": "array",
              "description": "History of prior repair attempts",
              "items": {
                "type": "object",
                "properties": {
                  "round_num": {
                    "type": "integer"
                  },
                  "strategy_used": {
                    "type": "string"
                  },
                  "outcome": {
                    "type": "string",
                    "enum": ["passed", "still_failed", "unknown"]
                  }
                }
              }
            },
            "repair_cap": {
              "type": "integer",
              "description": "Maximum repair rounds allowed by verification policy"
            }
          }
        },
        "verification_policy": {
          "type": "object",
          "description": "Policy constraints for this item's repair",
          "properties": {
            "repair_cap": {
              "type": "integer",
              "description": "Max repair attempts (typically 1-3)"
            },
            "spot_check_frac": {
              "type": "number",
              "description": "Fraction of items to spot-check (0.0-1.0)"
            },
            "require_adversarial_review": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "description": "The repair decision",
      "required": ["should_attempt_repair"],
      "properties": {
        "should_attempt_repair": {
          "type": "boolean",
          "description": "Is it worth attempting a repair?"
        },
        "repair_strategy": {
          "type": "string",
          "enum": ["root_cause_analysis", "incremental_fix", "full_rewrite", "escalate_to_human", "skip_item", "mark_for_manual_review"],
          "description": "If attempting repair, what strategy should be used"
        },
        "root_cause_hypothesis": {
          "type": "string",
          "description": "Best guess at why the test failed"
        },
        "failure_is_transient": {
          "type": "boolean",
          "description": "Is this a flaky test or genuinely broken code?"
        },
        "escalation_reason": {
          "type": "string",
          "description": "If not attempting repair, why not (e.g., 'cost_limit', 'repeated_failures', 'needs_architecture_change')"
        },
        "suggested_repair_prompt_addendum": {
          "type": "string",
          "description": "If attempting repair, what context to give the repair agent (test output + error analysis)"
        },
        "cost_estimate_dollars": {
          "type": "number",
          "description": "Estimated cost to attempt repair"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in this repair decision (0.0-1.0). Lower if the failure root cause is unclear."
    },
    "evidence": {
      "type": "array",
      "description": "Citations supporting the repair decision",
      "required": true,
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["test_output", "code_location", "prior_repair_history", "error_pattern_analysis"]
          },
          "description": {
            "type": "string",
            "description": "Why this evidence informs the repair decision"
          },
          "excerpt": {
            "type": "string",
            "description": "Relevant test output or code snippet"
          },
          "file": {
            "type": "string",
            "description": "File path if applicable"
          },
          "lines": {
            "type": "string",
            "description": "Line range if applicable"
          }
        }
      }
    }
  }
}
