{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rank Backlog Decision",
  "description": "Orchestrator S2 decision: intake audit findings, feature ideation, fleet-ops recommendations, and prior backlog; rank them by precedence for the current wave. Produces an ordered list of items with priority scores and justifications.",
  "type": "object",
  "required": ["verdict", "evidence", "ranked_items"],
  "properties": {
    "decision_type": {
      "type": "string",
      "const": "rank_backlog"
    },
    "input": {
      "type": "object",
      "description": "Context from control files consumed by this decision",
      "required": ["audit_findings", "backlog_items"],
      "properties": {
        "audit_findings": {
          "type": "array",
          "description": "Findings from read-only audit lenses (security, correctness, test-integrity, architecture, UI/UX, ideation, docs, fleet-ops)",
          "items": {
            "type": "object",
            "properties": {
              "lens": {
                "type": "string",
                "enum": ["security", "correctness", "test_integrity", "architecture", "ui_ux", "ideation", "docs", "fleet_ops", "github_currency", "portfolio_currency"]
              },
              "category": {
                "type": "string",
                "description": "Finding category: defect, enhancement, refactor, tech_debt, docs_drift"
              },
              "description": {
                "type": "string"
              },
              "impact": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              }
            }
          }
        },
        "backlog_items": {
          "type": "array",
          "description": "Existing backlog items not yet triaged",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["open", "in_progress", "done"]
              },
              "priority": {
                "type": "string",
                "enum": ["p0", "p1", "p2", "p3"]
              }
            }
          }
        },
        "fleet_ops_recommendations": {
          "type": "array",
          "description": "Standing recommendations from fleet-ops monitor",
          "items": {
            "type": "string"
          }
        },
        "wave_constraints": {
          "type": "object",
          "description": "Cost/time/capacity constraints for this wave",
          "properties": {
            "cost_ceiling_dollars": {
              "type": "number"
            },
            "max_items": {
              "type": "integer"
            }
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "description": "The ranking decision and scope for the wave",
      "required": ["scope_locked", "wave_items"],
      "properties": {
        "scope_locked": {
          "type": "boolean",
          "description": "True if this ranking will be locked for the wave (no new additions unless user overrides)"
        },
        "wave_items": {
          "type": "array",
          "description": "Ranked list of items selected for this wave, ordered by priority",
          "items": {
            "type": "object",
            "required": ["rank", "item_id", "priority", "estimated_cost"],
            "properties": {
              "rank": {
                "type": "integer",
                "description": "Execution order (1 = highest priority)"
              },
              "item_id": {
                "type": "string",
                "description": "Identifier from audit/backlog"
              },
              "priority": {
                "type": "string",
                "enum": ["p0", "p1", "p2", "p3"]
              },
              "reason": {
                "type": "string",
                "description": "Why this item is at this rank"
              },
              "estimated_cost": {
                "type": "number",
                "description": "Estimated cost in dollars"
              },
              "dependencies": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Item IDs that must ship before this one"
              }
            }
          }
        },
        "deferred_items": {
          "type": "array",
          "description": "Items deemed out-of-scope for this wave",
          "items": {
            "type": "object",
            "properties": {
              "item_id": {
                "type": "string"
              },
              "defer_reason": {
                "type": "string",
                "description": "Why deferred (cost, capacity, dependency, low priority)"
              }
            }
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in this ranking (0.0-1.0). Lower if findings are conflicting or constraints unclear."
    },
    "evidence": {
      "type": "array",
      "description": "Citations to files and line ranges that support this decision",
      "items": {
        "type": "object",
        "required": ["file", "description"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Relative path to control file (e.g., STATE.md, AUDIT-PRIMER.md, tracker.json)"
          },
          "lines": {
            "type": "string",
            "description": "Line range (e.g., '45-67') or line number"
          },
          "excerpt": {
            "type": "string",
            "description": "Quoted text supporting this citation"
          },
          "description": {
            "type": "string",
            "description": "How this evidence supports the decision"
          }
        }
      }
    }
  }
}
