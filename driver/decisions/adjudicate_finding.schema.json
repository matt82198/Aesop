{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adjudicate Finding Decision",
  "description": "Orchestrator S2 decision: given an audit finding (potential defect, false positive, enhancement opportunity), render a verdict: is it real? actionable? severity? backlog priority? Produces classification and a recommendation for wave inclusion.",
  "type": "object",
  "required": ["verdict", "evidence"],
  "properties": {
    "decision_type": {
      "type": "string",
      "const": "adjudicate_finding"
    },
    "input": {
      "type": "object",
      "description": "The finding to adjudicate and surrounding context",
      "required": ["finding", "finding_source"],
      "properties": {
        "finding": {
          "type": "object",
          "description": "The finding text and metadata from the audit lens",
          "required": ["description"],
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique finding identifier"
            },
            "description": {
              "type": "string",
              "description": "Full text of the finding"
            },
            "category": {
              "type": "string",
              "enum": ["defect", "false_positive", "enhancement", "refactor", "tech_debt", "docs_drift", "performance", "security", "other"]
            },
            "severity_claimed": {
              "type": "string",
              "enum": ["p0", "p1", "p2", "p3", "low", "medium", "high", "critical"]
            },
            "reproduction_steps": {
              "type": "string",
              "description": "How to reproduce if a defect"
            }
          }
        },
        "finding_source": {
          "type": "object",
          "description": "Which audit lens produced this finding",
          "required": ["lens", "file"],
          "properties": {
            "lens": {
              "type": "string",
              "description": "Audit lens role (e.g., 'security', 'correctness', 'test_integrity')"
            },
            "file": {
              "type": "string",
              "description": "Source file path if applicable"
            },
            "line": {
              "type": "integer",
              "description": "Line number in source if applicable"
            }
          }
        },
        "related_findings": {
          "type": "array",
          "description": "Other findings that may be duplicates or related",
          "items": {
            "type": "object",
            "properties": {
              "finding_id": {
                "type": "string"
              },
              "relationship": {
                "type": "string",
                "enum": ["duplicate", "related", "caused_by", "blocks"]
              }
            }
          }
        },
        "prior_verdicts": {
          "type": "array",
          "description": "Previous adjudication history for this finding category",
          "items": {
            "type": "object",
            "properties": {
              "wave": {
                "type": "integer"
              },
              "verdict": {
                "type": "string",
                "enum": ["real", "false_positive", "deferred", "fixed"]
              },
              "reasoning": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "description": "The adjudication decision",
      "required": ["classification", "actionable"],
      "properties": {
        "classification": {
          "type": "string",
          "enum": ["real_defect", "false_positive", "minor_quality", "doc_drift", "enhancement_opportunity", "undetermined"],
          "description": "Categorization of the finding"
        },
        "actionable": {
          "type": "boolean",
          "description": "Is this finding worth including in a wave backlog?"
        },
        "recommended_priority": {
          "type": "string",
          "enum": ["p0", "p1", "p2", "p3"],
          "description": "If actionable, what priority should it have in the backlog"
        },
        "severity_adjusted": {
          "type": "string",
          "enum": ["p0", "p1", "p2", "p3"],
          "description": "Refined severity if different from claimed"
        },
        "downgrade_reason": {
          "type": "string",
          "description": "If severity was downgraded, explain why (e.g., 'style issue, not logic defect')"
        },
        "why_false": {
          "type": "string",
          "description": "If classified as false_positive, explain the reasoning"
        },
        "suggested_fix_approach": {
          "type": "string",
          "description": "If actionable, a brief description of how to fix it (not a full implementation plan)"
        },
        "related_verdict": {
          "type": "object",
          "description": "If this finding is a duplicate/related, reference the primary",
          "properties": {
            "primary_finding_id": {
              "type": "string"
            },
            "relationship": {
              "type": "string"
            }
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in this verdict (0.0-1.0). Lower if finding is ambiguous or context-dependent."
    },
    "evidence": {
      "type": "array",
      "description": "Citations supporting this adjudication",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["code_location", "test_output", "prior_decision", "repro_result", "spec_reference"]
          },
          "file": {
            "type": "string",
            "description": "Source file path"
          },
          "lines": {
            "type": "string",
            "description": "Line range or number"
          },
          "excerpt": {
            "type": "string",
            "description": "Relevant code or text"
          },
          "description": {
            "type": "string",
            "description": "How this evidence supports the verdict"
          },
          "link": {
            "type": "string",
            "description": "Reference to PR, issue, commit hash, or prior wave"
          }
        }
      }
    }
  }
}
